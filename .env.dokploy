# Dokploy Environment Variables
# Copy these into your Dokploy CRM application settings

# ── Server Configuration ──
NODE_ENV=production
PORT=3000

# ── Database Configuration (PostgreSQL via Dokploy) ──
DB_TYPE=postgres
DATABASE_URL=postgresql://app-user:123456789@@Aa@crm-database-scijlk:5432/crm-db
PG_SSL_MODE=disable

# ── SMTP Configuration ──
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=b2b@pm-travelagency.cloud
SMTP_PASS=your_password_here
FROM_EMAIL=b2b@pm-travelagency.cloud
FROM_NAME=PM Travel Agency

# ── CRM Security ──
CRM_API_KEY=
CRM_ALLOWED_ORIGINS=

# ── Tracking & URLs ──
TRACKING_DOMAIN=https://www.pm-travelagency.com
CRM_URL=https://crm.yourdomain.com
N8N_URL=https://n8n.yourdomain.com
ADMIN_EMAIL=b2b@pm-travelagency.cloud

# ── AI Services (Optional) ──
GOOGLE_PLACES_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
SERP_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── WhatsApp Configuration (Optional) ──
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Twilio Configuration (Optional) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886

# IMPORTANT NOTES:
# 1. Copy all these variables into Dokploy CRM settings
# 2. DB_TYPE and DATABASE_URL are CRITICAL - without them, CRM defaults to SQLite
# 3. PostgreSQL host: crm-database-scijlk (internal hostname for Dokploy)
# 4. Both CRM and PostgreSQL must be on same network in Dokploy
# 5. Password special characters (@@Aa) must be preserved exactly
