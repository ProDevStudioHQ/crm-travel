# ──────────────────────────────────────────────
# PM Travel CRM — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Server ──
PORT=3000
NODE_ENV=production

# ── SMTP (Hostinger) ──
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=b2b@pm-travelagency.cloud
SMTP_PASS=your_password_here
FROM_EMAIL=b2b@pm-travelagency.cloud
FROM_NAME=PM Travel Agency

# ── CRM Security ──
CRM_API_KEY=
CRM_ALLOWED_ORIGINS=

# ── Tracking Domain (used for open/click tracking) ──
TRACKING_DOMAIN=https://www.pm-travelagency.com

# ── n8n Integration ──
N8N_URL=https://n8n.your-domain.com
CRM_URL=https://crm.your-domain.com
GOOGLE_PLACES_API_KEY=
ADMIN_EMAIL=b2b@pm-travelagency.cloud

# ── AI Lead Finder (search API keys — all optional, DuckDuckGo works free) ──
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
SERP_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── WhatsApp Cloud API (optional) ──
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Twilio WhatsApp (optional — alternative to Cloud API) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
